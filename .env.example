# ============================================================
# NOMINA DASHBOARD - VARIABLES DE ENTORNO
# Copiar este archivo como .env y completar los valores
# ============================================================

# --- APLICACION ---
APP_NAME=NóminaBoard
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=cambia_este_valor_por_una_clave_secreta_muy_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- BASE DE DATOS (PostgreSQL) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=nomina_dashboard
POSTGRES_USER=nomina_user
POSTGRES_PASSWORD=cambia_esta_contrasena_segura
DATABASE_URL=postgresql://nomina_user:cambia_esta_contrasena_segura@db:5432/nomina_dashboard

# --- CARPETA COMPARTIDA DE RED ---
# En Windows (servidor nativo): usar ruta UNC directa
# En Docker/Linux: montar via SMB o usar ruta mapeada
NETWORK_SHARE_PATH=\\\\192.168.0.13\\fs_sumimedical\\SUBGERENCIA ADMINISTRATIVA Y FINANCIERA\\DIRECCIÓN ADMINISTRATIVA\\NOVEDADES NOMINA\\CONSOLIDADO

# Credenciales para acceso a la carpeta compartida (opcional)
NETWORK_SHARE_USER=
NETWORK_SHARE_PASSWORD=
NETWORK_SHARE_DOMAIN=SUMIMEDICAL

# --- PROGRAMADOR (Scheduler) ---
# Día del mes para ejecución automática (30 = día 30 de cada mes)
SCHEDULER_DAY=30
SCHEDULER_HOUR=23
SCHEDULER_MINUTE=0

# --- REDIS (para Celery / cache, opcional) ---
REDIS_URL=redis://redis:6379/0

# --- CORS ---
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# --- LOGS ---
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# --- TRAZALO (BD PostgreSQL de RRHH, 2a fuente en tiempo real) ---
# IMPORTANTE: sin estos valores el sync de Trazalo se OMITE y los tableros
# quedan VACIOS en un despliegue nuevo. Configurar en el .env REAL del servidor
# (NUNCA commitear credenciales reales a este repo publico).
TRAZALO_DB_HOST=
TRAZALO_DB_PORT=5432
TRAZALO_DB_NAME=trazalo
TRAZALO_DB_USER=
TRAZALO_DB_PASSWORD=
# Cada cuantos minutos re-sincroniza (default 60)
TRAZALO_SYNC_INTERVAL_MINUTES=60
